import java.util.Scanner;

public class SistemaKFC {
    public static void main(String[] args) {

        Scanner escanner = new Scanner(System.in);

        String nombre;
        String direccion;
        String producto = "";

        int opcion;
        int cantidad;

        double precio = 0;
        double total;

        System.out.println("===== BIENVENIDO A KFC DELIVERY =====");

        System.out.print("Ingrese su nombre: ");
        nombre = escanner.nextLine();

        System.out.print("Ingrese su direccion: ");
        direccion = escanner.nextLine();

        System.out.println("\nMENU KFC");
        System.out.println("1. Combo KFC - S/25");
        System.out.println("2. Big Box - S/35");
        System.out.println("3. Pollo Broaster - S/18");
        System.out.print("Seleccione una opcion: ");
        opcion = escanner.nextInt();

        switch (opcion) {

            case 1:
                producto = "Combo KFC";
                precio = 25;
                break;

            case 2:
                producto = "Big Box";
                precio = 35;
                break;

            case 3:
                producto = "Pollo Broaster";
                precio = 18;
                break;

            default:
                System.out.println("Opcion no valida");
                escanner.close();
                return;
        }

        System.out.print("Ingrese cantidad: ");
        cantidad = escanner.nextInt();

        total = precio * cantidad;

        // costo fijo de envio
        total = total + 6;

        System.out.println("\n===== BOLETA =====");
        System.out.println("Cliente: " + nombre);
        System.out.println("Direccion: " + direccion);
        System.out.println("Producto: " + producto);
        System.out.println("Cantidad: " + cantidad);
        System.out.println("Costo de envio: S/6");
        System.out.println("Total a pagar: S/" + total);

        System.out.println("\nGracias por comprar en KFC Delivery");

        escanner.close();
    }
}
